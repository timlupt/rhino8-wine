# makepkg build artifacts (huge, regenerated by `makepkg -si`; Wine source already on GitHub at wine-mirror/wine)
src/
pkg/
wine-src/
*.pkg.tar.zst
*.pkg.tar.zst.sig

# Wineprefix — contains license credentials and 4+ GB of installed Windows software
wineprefix/

# Proprietary installers and redistributables
*.exe
redist/

# Temp files and logs
tmp/
*.log

# Claude session state
.claude/

# Local sandbox tooling for running Claude Code in an Arch container (dev convenience, not part of the port)
.docker/
claude-wine.sh

