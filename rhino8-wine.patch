diff --git a/dlls/ntdll/unix/thread.c b/dlls/ntdll/unix/thread.c
index 546963a4241..121a59836a9 100644
--- a/dlls/ntdll/unix/thread.c
+++ b/dlls/ntdll/unix/thread.c
@@ -1199,8 +1199,10 @@ NTSTATUS init_thread_stack( TEB *teb, ULONG_PTR limit, SIZE_T reserve_size, SIZE
         teb->Tib.StackLimit = stack.StackLimit;
         teb->DeallocationStack = stack.DeallocationStack;
 
-        /* 32-bit stack */
+        /* 32-bit stack - require at least 8 MB so .NET 8 initialization does not
+         * overflow; the PE header default of 1 MB is insufficient on Wine. */
         if (!limit || limit > user_space_wow_limit) limit = user_space_wow_limit;
+        if (reserve_size < 8 * 1024 * 1024) reserve_size = 8 * 1024 * 1024;
         if ((status = virtual_alloc_thread_stack( &stack, 0, limit, reserve_size, commit_size, TRUE )))
             return status;
         wow_teb->Tib.StackBase = PtrToUlong( stack.StackBase );
diff --git a/dlls/ntdll/unix/virtual.c b/dlls/ntdll/unix/virtual.c
index a2ea5244b9f..8f387b89f6b 100644
--- a/dlls/ntdll/unix/virtual.c
+++ b/dlls/ntdll/unix/virtual.c
@@ -4427,7 +4427,7 @@ NTSTATUS virtual_alloc_thread_stack( INITIAL_TEB *stack, ULONG_PTR limit_low, UL
         set_page_vprot( view->base, host_page_size, 0 );
         set_page_vprot( (char *)view->base + host_page_size, host_page_size,
                         VPROT_READ | VPROT_WRITE | VPROT_COMMITTED | VPROT_GUARD );
-        mprotect_range( view->base, 2 * host_page_size , 0, 0 );
+        mprotect_range( view->base, 2 * host_page_size, 0, 0 );
     }
     VIRTUAL_DEBUG_DUMP_VIEW( view );
 
@@ -5726,6 +5726,22 @@ static unsigned int fill_basic_memory_info( const void *addr, MEMORY_BASIC_INFOR
         if (view->protect & SEC_IMAGE) info->Type = MEM_IMAGE;
         else if (view->protect & (SEC_FILE | SEC_RESERVE | SEC_COMMIT)) info->Type = MEM_MAPPED;
         else info->Type = MEM_PRIVATE;
+
+        /* Clamp AllocationBase for thread stack regions: report at most 1 MB of
+         * stack to VirtualQuery callers so the .NET 8 CLR calibrates its
+         * recursion depth as on Windows (where stacks are typically 1 MB). */
+        {
+            TEB *teb = NtCurrentTeb();
+            if (teb &&
+                (char *)addr >= (char *)teb->DeallocationStack &&
+                (char *)addr < (char *)teb->Tib.StackBase)
+            {
+                char *clamped = (char *)teb->Tib.StackBase - (1 * 1024 * 1024);
+                if (clamped > (char *)teb->DeallocationStack &&
+                    (char *)info->AllocationBase <= (char *)teb->DeallocationStack + host_page_size)
+                    info->AllocationBase = clamped;
+            }
+        }
     }
     server_leave_uninterrupted_section( &virtual_mutex, &sigset );
 
diff --git a/dlls/wintrust/wintrust_main.c b/dlls/wintrust/wintrust_main.c
index 22921006d4a..7ccf31529b2 100644
--- a/dlls/wintrust/wintrust_main.c
+++ b/dlls/wintrust/wintrust_main.c
@@ -670,6 +670,36 @@ LONG WINAPI WinVerifyTrust( HWND hwnd, GUID *ActionID, LPVOID ActionData )
     TRACE("(%p, %s, %p)\n", hwnd, debugstr_guid(ActionID), ActionData);
     dump_wintrust_data(ActionData);
 
+    /* Override Authenticode trust — Wine's crypt32 cannot build a trust chain
+     * for real Microsoft certificates (missing CA store).  Run the real verify
+     * step so that the state data and signer/cert chain are populated for
+     * callers that need the cert context (e.g. Burn's thumbprint check), but
+     * always report success.  For CLOSE, fall through to the normal path so
+     * state is freed properly. */
+    if (IsEqualGUID(ActionID, &generic_verify_v2) ||
+        IsEqualGUID(ActionID, &generic_chain_verify))
+    {
+        DWORD stateAction = WTD_STATEACTION_IGNORE;
+        if (WVT_ISINSTRUCT(WINTRUST_DATA, actionData->cbStruct, dwStateAction))
+            stateAction = actionData->dwStateAction;
+        if (stateAction == WTD_STATEACTION_VERIFY)
+        {
+            /* Run real verify so hWVTStateData/signers/certs get populated,
+             * then override return value to success. */
+            WINTRUST_DefaultVerify(hwnd, ActionID, ActionData);
+            TRACE("overriding Authenticode VERIFY result to S_OK\n");
+            return ERROR_SUCCESS;
+        }
+        else if (stateAction == WTD_STATEACTION_IGNORE)
+        {
+            /* One-shot verify+close: run it to populate certs, return S_OK. */
+            WINTRUST_DefaultVerifyAndClose(hwnd, ActionID, ActionData);
+            TRACE("overriding Authenticode IGNORE result to S_OK\n");
+            return ERROR_SUCCESS;
+        }
+        /* WTD_STATEACTION_CLOSE: fall through to normal close path. */
+    }
+
     /* Support for known old-style callers: */
     if (IsEqualGUID(ActionID, &published_software))
         err = WINTRUST_PublishedSoftware(hwnd, ActionID, ActionData);
